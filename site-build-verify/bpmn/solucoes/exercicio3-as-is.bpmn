<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Exercicio3"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_PSP" name="PSP — Esquadra de Leiria" processRef="Process_PSP" />
    <bpmn:participant id="Participant_MP" name="Ministério Público" processRef="Process_MP" />
    <bpmn:messageFlow id="MsgFlow_1" name="Relatório" sourceRef="SendTask_EnviarMP" targetRef="StartEvent_MP" />
    <bpmn:messageFlow id="MsgFlow_2" name="Pedido de diligências" sourceRef="SendTask_PedirDiligencias" targetRef="CatchEvent_RespostaMP" />
  </bpmn:collaboration>

  <!-- ==================== PROCESSO PSP ==================== -->
  <bpmn:process id="Process_PSP" isExecutable="false">
    <bpmn:laneSet id="LaneSet_PSP">
      <bpmn:lane id="Lane_Agente" name="Agente">
        <bpmn:flowNodeRef>StartEvent_PSP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerificarIdentidade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistarQueixa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EntregarCopia</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oficial" name="Oficial">
        <bpmn:flowNodeRef>Task_ReverQueixa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TipoInvestigacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_ReencaminharPJ</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Reencaminhamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AtribuirAgente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_EnviarMP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_RespostaMP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RespostaMP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PSP</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AgenteInvestigador" name="Agente Investigador">
        <bpmn:flowNodeRef>Task_Diligencias</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_PSP" name="Cidadão dirige-se à esquadra">
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Reencaminhamento" name="Queixa reencaminhada">
      <bpmn:incoming>Flow_P6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_PSP" name="Processo concluído na PSP">
      <bpmn:incoming>Flow_P13</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:intermediateCatchEvent id="CatchEvent_RespostaMP" name="Resposta do MP">
      <bpmn:incoming>Flow_P10</bpmn:incoming>
      <bpmn:outgoing>Flow_P11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgEvtDef_RespostaMP" />
    </bpmn:intermediateCatchEvent>

    <!-- Tarefas — Lane Agente -->
    <bpmn:task id="Task_VerificarIdentidade" name="Verificar identidade do queixoso">
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegistarQueixa" name="Registar queixa em formulário (papel carbonado)">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:outgoing>Flow_P3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EntregarCopia" name="Entregar cópia da queixa ao cidadão">
      <bpmn:incoming>Flow_P3</bpmn:incoming>
      <bpmn:outgoing>Flow_P4</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Oficial -->
    <bpmn:task id="Task_ReverQueixa" name="Rever queixa e classificar tipo de crime">
      <bpmn:incoming>Flow_P4</bpmn:incoming>
      <bpmn:outgoing>Flow_P5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_TipoInvestigacao" name="Investigação interna ou reencaminhamento?">
      <bpmn:incoming>Flow_P5</bpmn:incoming>
      <bpmn:outgoing>Flow_P5a</bpmn:outgoing>
      <bpmn:outgoing>Flow_P7</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_ReencaminharPJ" name="Reencaminhar para PJ/GNR">
      <bpmn:incoming>Flow_P5a</bpmn:incoming>
      <bpmn:outgoing>Flow_P6</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_AtribuirAgente" name="Atribuir a agente investigador">
      <bpmn:incoming>Flow_P7</bpmn:incoming>
      <bpmn:outgoing>Flow_P8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_EnviarMP" name="Enviar relatório ao MP por correio interno">
      <bpmn:incoming>Flow_P9</bpmn:incoming>
      <bpmn:outgoing>Flow_P10</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_RespostaMP" name="Diligências complementares?">
      <bpmn:incoming>Flow_P11</bpmn:incoming>
      <bpmn:outgoing>Flow_P12</bpmn:outgoing>
      <bpmn:outgoing>Flow_P13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Tarefas — Lane Agente Investigador -->
    <bpmn:task id="Task_Diligencias" name="Realizar diligências e elaborar relatório">
      <bpmn:incoming>Flow_P8</bpmn:incoming>
      <bpmn:incoming>Flow_P12</bpmn:incoming>
      <bpmn:outgoing>Flow_P9</bpmn:outgoing>
    </bpmn:task>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_P1" sourceRef="StartEvent_PSP" targetRef="Task_VerificarIdentidade" />
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="Task_VerificarIdentidade" targetRef="Task_RegistarQueixa" />
    <bpmn:sequenceFlow id="Flow_P3" sourceRef="Task_RegistarQueixa" targetRef="Task_EntregarCopia" />
    <bpmn:sequenceFlow id="Flow_P4" sourceRef="Task_EntregarCopia" targetRef="Task_ReverQueixa" />
    <bpmn:sequenceFlow id="Flow_P5" sourceRef="Task_ReverQueixa" targetRef="Gateway_TipoInvestigacao" />
    <bpmn:sequenceFlow id="Flow_P5a" name="Reencaminhamento PJ/GNR" sourceRef="Gateway_TipoInvestigacao" targetRef="SendTask_ReencaminharPJ" />
    <bpmn:sequenceFlow id="Flow_P6" sourceRef="SendTask_ReencaminharPJ" targetRef="EndEvent_Reencaminhamento" />
    <bpmn:sequenceFlow id="Flow_P7" name="Investigação interna" sourceRef="Gateway_TipoInvestigacao" targetRef="Task_AtribuirAgente" />
    <bpmn:sequenceFlow id="Flow_P8" sourceRef="Task_AtribuirAgente" targetRef="Task_Diligencias" />
    <bpmn:sequenceFlow id="Flow_P9" sourceRef="Task_Diligencias" targetRef="SendTask_EnviarMP" />
    <bpmn:sequenceFlow id="Flow_P10" sourceRef="SendTask_EnviarMP" targetRef="CatchEvent_RespostaMP" />
    <bpmn:sequenceFlow id="Flow_P11" sourceRef="CatchEvent_RespostaMP" targetRef="Gateway_RespostaMP" />
    <bpmn:sequenceFlow id="Flow_P12" name="Sim — diligências complementares" sourceRef="Gateway_RespostaMP" targetRef="Task_Diligencias" />
    <bpmn:sequenceFlow id="Flow_P13" name="Não" sourceRef="Gateway_RespostaMP" targetRef="EndEvent_PSP" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Formulário em papel carbonado — texto ilegível</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Task_RegistarQueixa" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Comunicação com MP por correio interno — atrasos de dias/semanas</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="SendTask_EnviarMP" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Cidadão sem qualquer actualização do estado</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="Task_AtribuirAgente" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <!-- ==================== PROCESSO MP ==================== -->
  <bpmn:process id="Process_MP" isExecutable="false">

    <bpmn:startEvent id="StartEvent_MP" name="Relatório recebido da PSP">
      <bpmn:outgoing>Flow_M1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgEvtDef_StartMP" />
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_DecisaoMP" name="Decisão do MP?">
      <bpmn:incoming>Flow_M1</bpmn:incoming>
      <bpmn:outgoing>Flow_M2</bpmn:outgoing>
      <bpmn:outgoing>Flow_M3</bpmn:outgoing>
      <bpmn:outgoing>Flow_M4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Acusar" name="Deduzir acusação">
      <bpmn:incoming>Flow_M2</bpmn:incoming>
      <bpmn:outgoing>Flow_M5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Arquivar" name="Arquivar processo">
      <bpmn:incoming>Flow_M3</bpmn:incoming>
      <bpmn:outgoing>Flow_M6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_PedirDiligencias" name="Enviar pedido de diligências">
      <bpmn:incoming>Flow_M4</bpmn:incoming>
      <bpmn:outgoing>Flow_M7</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_MP_Acusacao" name="Acusação deduzida">
      <bpmn:incoming>Flow_M5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_MP_Arquivado" name="Processo arquivado">
      <bpmn:incoming>Flow_M6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_MP_Diligencias" name="Pedido de diligências enviado">
      <bpmn:incoming>Flow_M7</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Fluxos de sequência MP -->
    <bpmn:sequenceFlow id="Flow_M1" sourceRef="StartEvent_MP" targetRef="Gateway_DecisaoMP" />
    <bpmn:sequenceFlow id="Flow_M2" name="Acusar" sourceRef="Gateway_DecisaoMP" targetRef="Task_Acusar" />
    <bpmn:sequenceFlow id="Flow_M3" name="Arquivar" sourceRef="Gateway_DecisaoMP" targetRef="Task_Arquivar" />
    <bpmn:sequenceFlow id="Flow_M4" name="Pedir diligências complementares" sourceRef="Gateway_DecisaoMP" targetRef="SendTask_PedirDiligencias" />
    <bpmn:sequenceFlow id="Flow_M5" sourceRef="Task_Acusar" targetRef="EndEvent_MP_Acusacao" />
    <bpmn:sequenceFlow id="Flow_M6" sourceRef="Task_Arquivar" targetRef="EndEvent_MP_Arquivado" />
    <bpmn:sequenceFlow id="Flow_M7" sourceRef="SendTask_PedirDiligencias" targetRef="EndEvent_MP_Diligencias" />

  </bpmn:process>

  <!-- ==================== DIAGRAMA ==================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool PSP -->
      <bpmndi:BPMNShape id="Participant_PSP_di" bpmnElement="Participant_PSP" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1600" height="750" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes PSP -->
      <bpmndi:BPMNShape id="Lane_Agente_di" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1570" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Oficial_di" bpmnElement="Lane_Oficial" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1570" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AgenteInvestigador_di" bpmnElement="Lane_AgenteInvestigador" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1570" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Pool MP -->
      <bpmndi:BPMNShape id="Participant_MP_di" bpmnElement="Participant_MP" isHorizontal="true">
        <dc:Bounds x="160" y="870" width="1600" height="350" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- ===== Shapes — PSP ===== -->

      <!-- Start Event PSP -->
      <bpmndi:BPMNShape id="StartEvent_PSP_di" bpmnElement="StartEvent_PSP">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="226" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Verificar identidade -->
      <bpmndi:BPMNShape id="Task_VerificarIdentidade_di" bpmnElement="Task_VerificarIdentidade">
        <dc:Bounds x="330" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Registar queixa -->
      <bpmndi:BPMNShape id="Task_RegistarQueixa_di" bpmnElement="Task_RegistarQueixa">
        <dc:Bounds x="480" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Entregar cópia -->
      <bpmndi:BPMNShape id="Task_EntregarCopia_di" bpmnElement="Task_EntregarCopia">
        <dc:Bounds x="630" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Rever queixa (Oficial) -->
      <bpmndi:BPMNShape id="Task_ReverQueixa_di" bpmnElement="Task_ReverQueixa">
        <dc:Bounds x="330" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Tipo investigação -->
      <bpmndi:BPMNShape id="Gateway_TipoInvestigacao_di" bpmnElement="Gateway_TipoInvestigacao" isMarkerVisible="true">
        <dc:Bounds x="485" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="465" y="467" width="90" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SendTask: Reencaminhar PJ/GNR -->
      <bpmndi:BPMNShape id="SendTask_ReencaminharPJ_di" bpmnElement="SendTask_ReencaminharPJ">
        <dc:Bounds x="580" y="330" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event: Reencaminhamento -->
      <bpmndi:BPMNShape id="EndEvent_Reencaminhamento_di" bpmnElement="EndEvent_Reencaminhamento">
        <dc:Bounds x="732" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="710" y="395" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Atribuir agente -->
      <bpmndi:BPMNShape id="Task_AtribuirAgente_di" bpmnElement="Task_AtribuirAgente">
        <dc:Bounds x="630" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Diligências (Agente Investigador) -->
      <bpmndi:BPMNShape id="Task_Diligencias_di" bpmnElement="Task_Diligencias">
        <dc:Bounds x="830" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- SendTask: Enviar relatório ao MP -->
      <bpmndi:BPMNShape id="SendTask_EnviarMP_di" bpmnElement="SendTask_EnviarMP">
        <dc:Bounds x="1000" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Intermediate Catch Event: Resposta MP -->
      <bpmndi:BPMNShape id="CatchEvent_RespostaMP_di" bpmnElement="CatchEvent_RespostaMP">
        <dc:Bounds x="1162" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1140" y="460" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway: Resposta MP -->
      <bpmndi:BPMNShape id="Gateway_RespostaMP_di" bpmnElement="Gateway_RespostaMP" isMarkerVisible="true">
        <dc:Bounds x="1255" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1235" y="380" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End Event PSP -->
      <bpmndi:BPMNShape id="EndEvent_PSP_di" bpmnElement="EndEvent_PSP">
        <dc:Bounds x="1392" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1365" y="460" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ===== Shapes — MP ===== -->

      <!-- Start Event MP (message) -->
      <bpmndi:BPMNShape id="StartEvent_MP_di" bpmnElement="StartEvent_MP">
        <dc:Bounds x="352" y="1027" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="326" y="1070" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway: Decisão MP -->
      <bpmndi:BPMNShape id="Gateway_DecisaoMP_di" bpmnElement="Gateway_DecisaoMP" isMarkerVisible="true">
        <dc:Bounds x="485" y="1020" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="472" y="990" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Acusar -->
      <bpmndi:BPMNShape id="Task_Acusar_di" bpmnElement="Task_Acusar">
        <dc:Bounds x="630" y="910" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Arquivar -->
      <bpmndi:BPMNShape id="Task_Arquivar_di" bpmnElement="Task_Arquivar">
        <dc:Bounds x="630" y="1005" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- SendTask: Pedir diligências -->
      <bpmndi:BPMNShape id="SendTask_PedirDiligencias_di" bpmnElement="SendTask_PedirDiligencias">
        <dc:Bounds x="630" y="1100" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Events MP -->
      <bpmndi:BPMNShape id="EndEvent_MP_Acusacao_di" bpmnElement="EndEvent_MP_Acusacao">
        <dc:Bounds x="802" y="932" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="780" y="975" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_MP_Arquivado_di" bpmnElement="EndEvent_MP_Arquivado">
        <dc:Bounds x="802" y="1027" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="780" y="1070" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_MP_Diligencias_di" bpmnElement="EndEvent_MP_Diligencias">
        <dc:Bounds x="802" y="1122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="775" y="1165" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ===== Annotations ===== -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="460" y="70" width="220" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="970" y="330" width="280" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="620" y="530" width="230" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- ===== Edges — PSP ===== -->

      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <di:waypoint x="288" y="185" />
        <di:waypoint x="330" y="185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <di:waypoint x="430" y="185" />
        <di:waypoint x="480" y="185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P3_di" bpmnElement="Flow_P3">
        <di:waypoint x="580" y="185" />
        <di:waypoint x="630" y="185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P4_di" bpmnElement="Flow_P4">
        <di:waypoint x="730" y="185" />
        <di:waypoint x="760" y="185" />
        <di:waypoint x="760" y="435" />
        <di:waypoint x="330" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_P5_di" bpmnElement="Flow_P5">
        <di:waypoint x="430" y="435" />
