<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Ex2"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_ESTG" name="ESTG-IPL — Pedido de Equivalência de UC (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Estudante" name="Estudante">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SA" name="Serviços Académicos">
        <bpmn:flowNodeRef>Task_VerificarDoc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DocCompleta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ContactarEstudante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistarPedido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarDeferimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarIndeferimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Deferido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Indeferido</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Coordenador" name="Coordenador de Curso">
        <bpmn:flowNodeRef>Task_IdentificarDocente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EncaminharDocente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecolherPareceres</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarProposta</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Docente" name="Docente">
        <bpmn:flowNodeRef>Task_CompararProgramas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CTC" name="CTC (Conselho Técnico-Científico)">
        <bpmn:flowNodeRef>Task_Deliberar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Resultado</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Estudante entrega requerimento com documentação">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Deferido" name="Processo concluído (Deferido)">
      <bpmn:incoming>Flow_Def2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Indeferido" name="Processo concluído (Indeferido)">
      <bpmn:incoming>Flow_Ind2</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Tarefas — Lane Serviços Académicos -->
    <bpmn:task id="Task_VerificarDoc" name="Verificar documentação">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ContactarEstudante" name="Contactar estudante para documentos em falta">
      <bpmn:incoming>Flow_DocNao</bpmn:incoming>
      <bpmn:outgoing>Flow_Loop</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegistarPedido" name="Registar pedido em Excel e encaminhar ao coordenador">
      <bpmn:incoming>Flow_DocSim</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ComunicarDeferimento" name="Comunicar deferimento e actualizar plano curricular">
      <bpmn:incoming>Flow_Def1</bpmn:incoming>
      <bpmn:outgoing>Flow_Def2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ComunicarIndeferimento" name="Comunicar indeferimento ao estudante">
      <bpmn:incoming>Flow_Ind1</bpmn:incoming>
      <bpmn:outgoing>Flow_Ind2</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Coordenador -->
    <bpmn:task id="Task_IdentificarDocente" name="Identificar docente(s) responsável(eis)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EncaminharDocente" name="Encaminhar pedido ao docente por email">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RecolherPareceres" name="Recolher pareceres e elaborar proposta">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnviarProposta" name="Enviar proposta ao CTC">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Docente -->
    <bpmn:task id="Task_CompararProgramas" name="Comparar programas e emitir parecer">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane CTC -->
    <bpmn:task id="Task_Deliberar" name="Deliberar em reunião">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateways -->
    <bpmn:exclusiveGateway id="Gateway_DocCompleta" name="Documentação completa?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_DocNao</bpmn:outgoing>
      <bpmn:outgoing>Flow_DocSim</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Resultado" name="Resultado da deliberação?">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Def1</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ind1</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarDoc" targetRef="Gateway_DocCompleta" />
    <bpmn:sequenceFlow id="Flow_DocNao" name="Não" sourceRef="Gateway_DocCompleta" targetRef="Task_ContactarEstudante" />
    <bpmn:sequenceFlow id="Flow_Loop" sourceRef="Task_ContactarEstudante" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_DocSim" name="Sim" sourceRef="Gateway_DocCompleta" targetRef="Task_RegistarPedido" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_RegistarPedido" targetRef="Task_IdentificarDocente" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_IdentificarDocente" targetRef="Task_EncaminharDocente" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_EncaminharDocente" targetRef="Task_CompararProgramas" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_CompararProgramas" targetRef="Task_RecolherPareceres" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_RecolherPareceres" targetRef="Task_EnviarProposta" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_EnviarProposta" targetRef="Task_Deliberar" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_Deliberar" targetRef="Gateway_Resultado" />
    <bpmn:sequenceFlow id="Flow_Def1" name="Deferido" sourceRef="Gateway_Resultado" targetRef="Task_ComunicarDeferimento" />
    <bpmn:sequenceFlow id="Flow_Ind1" name="Indeferido" sourceRef="Gateway_Resultado" targetRef="Task_ComunicarIndeferimento" />
    <bpmn:sequenceFlow id="Flow_Def2" sourceRef="Task_ComunicarDeferimento" targetRef="EndEvent_Deferido" />
    <bpmn:sequenceFlow id="Flow_Ind2" sourceRef="Task_ComunicarIndeferimento" targetRef="EndEvent_Indeferido" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Email como ferramenta de workflow — sem rastreabilidade</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Task_EncaminharDocente" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Estudante sem visibilidade do estado do pedido</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="Task_RegistarPedido" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Sem prazo definido para parecer do docente — bloqueio total</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="Task_CompararProgramas" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_ESTG_di" bpmnElement="Participant_ESTG" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1700" height="1250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Estudante_di" bpmnElement="Lane_Estudante" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SA_di" bpmnElement="Lane_SA" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Coordenador_di" bpmnElement="Lane_Coordenador" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Docente_di" bpmnElement="Lane_Docente" isHorizontal="true">
        <dc:Bounds x="190" y="810" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_CTC_di" bpmnElement="Lane_CTC" isHorizontal="true">
        <dc:Bounds x="190" y="1060" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event (Estudante lane) -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="272" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="246" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Tasks — Serviços Académicos -->
      <bpmndi:BPMNShape id="Task_VerificarDoc_di" bpmnElement="Task_VerificarDoc">
        <dc:Bounds x="330" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_DocCompleta_di" bpmnElement="Gateway_DocCompleta" isMarkerVisible="true">
        <dc:Bounds x="485" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="540" y="425" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ContactarEstudante_di" bpmnElement="Task_ContactarEstudante">
        <dc:Bounds x="460" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_RegistarPedido_di" bpmnElement="Task_RegistarPedido">
        <dc:Bounds x="600" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ComunicarDeferimento_di" bpmnElement="Task_ComunicarDeferimento">
        <dc:Bounds x="1380" y="370" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ComunicarIndeferimento_di" bpmnElement="Task_ComunicarIndeferimento">
        <dc:Bounds x="1380" y="470" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Events — Serviços Académicos -->
      <bpmndi:BPMNShape id="EndEvent_Deferido_di" bpmnElement="EndEvent_Deferido">
        <dc:Bounds x="1542" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1520" y="435" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Indeferido_di" bpmnElement="EndEvent_Indeferido">
        <dc:Bounds x="1542" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1520" y="535" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Tasks — Coordenador -->
      <bpmndi:BPMNShape id="Task_IdentificarDocente_di" bpmnElement="Task_IdentificarDocente">
        <dc:Bounds x="600" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EncaminharDocente_di" bpmnElement="Task_EncaminharDocente">
        <dc:Bounds x="760" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_RecolherPareceres_di" bpmnElement="Task_RecolherPareceres">
        <dc:Bounds x="1000" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EnviarProposta_di" bpmnElement="Task_EnviarProposta">
        <dc:Bounds x="1150" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tasks — Docente -->
      <bpmndi:BPMNShape id="Task_CompararProgramas_di" bpmnElement="Task_CompararProgramas">
        <dc:Bounds x="880" y="895" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tasks — CTC -->
      <bpmndi:BPMNShape id="Task_Deliberar_di" bpmnElement="Task_Deliberar">
        <dc:Bounds x="1150" y="1145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Resultado_di" bpmnElement="Gateway_Resultado" isMarkerVisible="true">
        <dc:Bounds x="1305" y="1160" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1360" y="1175" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Annotations -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="700" y="760" width="240" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="560" y="540" width="220" height="30" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="830" y="990" width="260" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="290" y="203" />
        <di:waypoint x="290" y="435" />
        <di:waypoint x="330" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="435" />
        <di:waypoint x="485" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_DocNao_di" bpmnElement="Flow_DocNao">
        <di:waypoint x="510" y="410" />
        <di:waypoint x="510" y="415" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="515" y="393" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Loop_di" bpmnElement="Flow_Loop">
        <di:waypoint x="460" y="375" />
        <di:waypoint x="380" y="375" />
        <di:waypoint x="380" y="395" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_DocSim_di" bpmnElement="Flow_DocSim">
        <di:waypoint x="510" y="460" />
        <di:waypoint x="510" y="495" />
        <di:waypoint x="600" y="495" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="473" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="650" y="535" />
        <di:waypoint x="650" y="645" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="700" y="685" />
        <di:waypoint x="760" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="810" y="725" />
        <di:waypoint x="810" y="935" />
        <di:waypoint x="880" y="935" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="980" y="935" />
        <di:waypoint x="1050" y="935" />
        <di:waypoint x="1050" y="725" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1100" y="685" />
        <di:waypoint x="1150" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1200" y="725" />
        <di:waypoint x="1200" y="1145" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1250" y="1185" />
        <di:waypoint x="1305" y="1185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Def1_di" bpmnElement="Flow_Def1">
        <di:waypoint x="1330" y="1160" />
        <di:waypoint x="1330" y="410" />
        <di:waypoint x="1380" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1335" y="780" width="42" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Ind1_di" bpmnElement="Flow_Ind1">
        <di:waypoint x="1355" y="1185" />
        <di:waypoint x="1370" y="1185" />
        <di:waypoint x="1370" y="510" />
        <di:waypoint x="1380" y="510" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1375" y="850" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Def2_di" bpmnElement="Flow_Def2">
        <di:waypoint x="1480" y="410" />
        <di:waypoint x="1542" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Ind2_di" bpmnElement="Flow_Ind2">
        <di:waypoint x="1480" y="510" />
        <di:waypoint x="1542" y="510" />
      </bpmndi:BPMNEdge>

      <!-- Associations -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="810" y="725" />
        <di:waypoint x="810" y="760" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="650" y="535" />
        <di:waypoint x="650" y="540" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="930" y="975" />
        <di:waypoint x="930" y="990" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
