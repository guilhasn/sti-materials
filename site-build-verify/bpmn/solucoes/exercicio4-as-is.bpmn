<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Exercicio4"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_JuntaFreguesia" name="Junta de Freguesia de Marinha Grande — Licença de Ocupação de Via Pública (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Requerente" name="Requerente">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PagarTaxa</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Funcionario" name="Funcionário">
        <bpmn:flowNodeRef>Task_VerificarDoc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ViaMunicipal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_ReencaminharCamara</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Camara</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarIndeferimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Indeferido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarDecisao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirAlvara</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_ComunicarGNR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OrgaoDeliberativo" name="Órgão Deliberativo">
        <bpmn:flowNodeRef>Task_AnalisarParecer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IncluirReuniao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DecisaoJunta</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Requerente entrega formulário com planta">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Camara" name="Pedido reencaminhado à câmara">
      <bpmn:incoming>Flow_3a</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Indeferido" name="Pedido indeferido">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Final" name="Licença emitida">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Tarefas — Lane Funcionário -->
    <bpmn:task id="Task_VerificarDoc" name="Verificar documentação">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ViaMunicipal" name="Via é municipal?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_ReencaminharCamara" name="Reencaminhar pedido à câmara por ofício">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_3a</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ComunicarIndeferimento" name="Comunicar indeferimento por carta">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ComunicarDecisao" name="Comunicar decisão ao requerente por carta">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EmitirAlvara" name="Emitir alvará de licença">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_ComunicarGNR" name="Comunicar à GNR por ofício (condicionamento de trânsito)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- Tarefas — Lane Requerente -->
    <bpmn:task id="Task_PagarTaxa" name="Pagar taxa de ocupação no balcão">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Órgão Deliberativo -->
    <bpmn:task id="Task_AnalisarParecer" name="Presidente da junta analisa e emite parecer">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_IncluirReuniao" name="Incluir na reunião de junta para deliberação">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DecisaoJunta" name="Decisão da junta?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarDoc" targetRef="Gateway_ViaMunicipal" />
    <bpmn:sequenceFlow id="Flow_3" name="Sim" sourceRef="Gateway_ViaMunicipal" targetRef="SendTask_ReencaminharCamara" />
    <bpmn:sequenceFlow id="Flow_3a" sourceRef="SendTask_ReencaminharCamara" targetRef="EndEvent_Camara" />
    <bpmn:sequenceFlow id="Flow_4" name="Não (é da freguesia)" sourceRef="Gateway_ViaMunicipal" targetRef="Task_AnalisarParecer" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_AnalisarParecer" targetRef="Task_IncluirReuniao" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_IncluirReuniao" targetRef="Gateway_DecisaoJunta" />
    <bpmn:sequenceFlow id="Flow_7" name="Indeferido" sourceRef="Gateway_DecisaoJunta" targetRef="Task_ComunicarIndeferimento" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ComunicarIndeferimento" targetRef="EndEvent_Indeferido" />
    <bpmn:sequenceFlow id="Flow_9" name="Deferido / Deferido com condições" sourceRef="Gateway_DecisaoJunta" targetRef="Task_ComunicarDecisao" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_ComunicarDecisao" targetRef="Task_PagarTaxa" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_PagarTaxa" targetRef="Task_EmitirAlvara" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_EmitirAlvara" targetRef="SendTask_ComunicarGNR" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="SendTask_ComunicarGNR" targetRef="EndEvent_Final" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Formulário em papel sem modelo padronizado — informação incompleta</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="StartEvent_1" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Deliberação apenas em reunião quinzenal/mensal — 2-4 semanas de espera</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="Task_IncluirReuniao" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Sem verificação de reposição da via após obras</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="SendTask_ComunicarGNR" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_JuntaFreguesia_di" bpmnElement="Participant_JuntaFreguesia" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1560" height="750" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Requerente_di" bpmnElement="Lane_Requerente" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Funcionario_di" bpmnElement="Lane_Funcionario" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_OrgaoDeliberativo_di" bpmnElement="Lane_OrgaoDeliberativo" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- ===== Shapes ===== -->

      <!-- Start Event (Requerente) -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="226" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Verificar documentação (Funcionário) -->
      <bpmndi:BPMNShape id="Task_VerificarDoc_di" bpmnElement="Task_VerificarDoc">
        <dc:Bounds x="330" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Via municipal? -->
      <bpmndi:BPMNShape id="Gateway_ViaMunicipal_di" bpmnElement="Gateway_ViaMunicipal" isMarkerVisible="true">
        <dc:Bounds x="485" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="540" y="425" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SendTask: Reencaminhar câmara -->
      <bpmndi:BPMNShape id="SendTask_ReencaminharCamara_di" bpmnElement="SendTask_ReencaminharCamara">
        <dc:Bounds x="580" y="330" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event: Câmara -->
      <bpmndi:BPMNShape id="EndEvent_Camara_di" bpmnElement="EndEvent_Camara">
        <dc:Bounds x="732" y="352" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="706" y="395" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Analisar parecer (Órgão Deliberativo) -->
      <bpmndi:BPMNShape id="Task_AnalisarParecer_di" bpmnElement="Task_AnalisarParecer">
        <dc:Bounds x="580" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Incluir reunião (Órgão Deliberativo) -->
      <bpmndi:BPMNShape id="Task_IncluirReuniao_di" bpmnElement="Task_IncluirReuniao">
        <dc:Bounds x="740" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Decisão junta -->
      <bpmndi:BPMNShape id="Gateway_DecisaoJunta_di" bpmnElement="Gateway_DecisaoJunta" isMarkerVisible="true">
        <dc:Bounds x="895" y="660" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="880" y="717" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Comunicar indeferimento (Funcionário) -->
      <bpmndi:BPMNShape id="Task_ComunicarIndeferimento_di" bpmnElement="Task_ComunicarIndeferimento">
        <dc:Bounds x="870" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event: Indeferido -->
      <bpmndi:BPMNShape id="EndEvent_Indeferido_di" bpmnElement="EndEvent_Indeferido">
        <dc:Bounds x="1012" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="990" y="460" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Comunicar decisão (Funcionário) -->
      <bpmndi:BPMNShape id="Task_ComunicarDecisao_di" bpmnElement="Task_ComunicarDecisao">
        <dc:Bounds x="1050" y="480" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Pagar taxa (Requerente) -->
      <bpmndi:BPMNShape id="Task_PagarTaxa_di" bpmnElement="Task_PagarTaxa">
        <dc:Bounds x="1050" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Emitir alvará (Funcionário) -->
      <bpmndi:BPMNShape id="Task_EmitirAlvara_di" bpmnElement="Task_EmitirAlvara">
        <dc:Bounds x="1220" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- SendTask: Comunicar GNR -->
      <bpmndi:BPMNShape id="SendTask_ComunicarGNR_di" bpmnElement="SendTask_ComunicarGNR">
        <dc:Bounds x="1380" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event: Final -->
      <bpmndi:BPMNShape id="EndEvent_Final_di" bpmnElement="EndEvent_Final">
        <dc:Bounds x="1542" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1520" y="460" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ===== Annotations ===== -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="220" y="70" width="260" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="700" y="770" width="290" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="1350" y="330" width="220" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- ===== Edges ===== -->

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="270" y="203" />
        <di:waypoint x="270" y="435" />
        <di:waypoint x="330" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="435" />
        <di:waypoint x="485" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="510" y="410" />
        <di:waypoint x="510" y="370" />
        <di:waypoint x="580" y="370" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="378" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3a_di" bpmnElement="Flow_3a">
        <di:waypoint x="680" y="370" />
        <di:waypoint x="732" y="370" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="510" y="460" />
        <di:waypoint x="510" y="685" />
        <di:waypoint x="580" y="685" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="515" y="570" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="680" y="685" />
        <di:waypoint x="740" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="840" y="685" />
        <di:waypoint x="895" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="920" y="660" />
        <di:waypoint x="920" y="475" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="925" y="560" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="970" y="435" />
        <di:waypoint x="1012" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="945" y="685" />
        <di:waypoint x="1000" y="685" />
        <di:waypoint x="1000" y="520" />
        <di:waypoint x="1050" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="950" y="695" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1100" y="480" />
        <di:waypoint x="1100" y="225" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1150" y="185" />
        <di:waypoint x="1270" y="185" />
        <di:waypoint x="1270" y="395" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1320" y="435" />
        <di:waypoint x="1380" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1480" y="435" />
        <di:waypoint x="1542" y="435" />
      </bpmndi:BPMNEdge>

      <!-- Associations -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="270" y="167" />
        <di:waypoint x="300" y="110" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="790" y="725" />
        <di:waypoint x="800" y="770" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="1430" y="395" />
        <di:waypoint x="1420" y="370" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
