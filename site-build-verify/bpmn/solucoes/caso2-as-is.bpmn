<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Caso2"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Escola" name="Escola Secundária Domingos Sequeira — Pedido de Matrícula / Transferência (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_EE" name="Encarregado de Educação (EE)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Secretaria" name="Secretaria">
        <bpmn:flowNodeRef>Task_VerificarDoc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DocCompleta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ContactarEE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistarSIGE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Transferencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_PedirProcesso</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarEE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ActualizarHorario</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParOpen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParClose</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Direccao" name="Direcção">
        <bpmn:flowNodeRef>Task_DistribuirTurmas</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="EE entrega formulário de matrícula">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Final" name="Processo concluído">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Tarefas — Lane Secretaria -->
    <bpmn:task id="Task_VerificarDoc" name="Verificar documentação">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:incoming>Flow_LoopBack</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ContactarEE" name="Contactar EE por telefone">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopBack</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegistarSIGE" name="Registar matrícula no SIGE">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_PedirProcesso" name="Pedir processo à escola de origem (ofício)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_NotificarEE" name="Notificar EE da turma atribuída">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ActualizarHorario" name="Actualizar horário no sistema">
      <bpmn:incoming>Flow_11b</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Direcção -->
    <bpmn:task id="Task_DistribuirTurmas" name="Distribuir alunos pelas turmas">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateways -->
    <bpmn:exclusiveGateway id="Gateway_DocCompleta" name="Documentação completa?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Transferencia" name="É transferência?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="Gateway_ParOpen">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_11b</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_ParClose">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarDoc" targetRef="Gateway_DocCompleta" />
    <bpmn:sequenceFlow id="Flow_3" name="Não" sourceRef="Gateway_DocCompleta" targetRef="Task_ContactarEE" />
    <bpmn:sequenceFlow id="Flow_LoopBack" sourceRef="Task_ContactarEE" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_5" name="Sim" sourceRef="Gateway_DocCompleta" targetRef="Task_RegistarSIGE" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_RegistarSIGE" targetRef="Gateway_Transferencia" />
    <bpmn:sequenceFlow id="Flow_7" name="Sim" sourceRef="Gateway_Transferencia" targetRef="SendTask_PedirProcesso" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="SendTask_PedirProcesso" targetRef="Task_DistribuirTurmas" />
    <bpmn:sequenceFlow id="Flow_9" name="Não" sourceRef="Gateway_Transferencia" targetRef="Task_DistribuirTurmas" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_DistribuirTurmas" targetRef="Gateway_ParOpen" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gateway_ParOpen" targetRef="Task_NotificarEE" />
    <bpmn:sequenceFlow id="Flow_11b" sourceRef="Gateway_ParOpen" targetRef="Task_ActualizarHorario" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_NotificarEE" targetRef="Gateway_ParClose" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_ActualizarHorario" targetRef="Gateway_ParClose" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Gateway_ParClose" targetRef="EndEvent_Final" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Formulário em papel — risco de extravio</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="StartEvent_1" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Introdução manual no SIGE — erros de transcrição</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="Task_RegistarSIGE" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Ofício em papel para escola de origem — semanas de espera</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="SendTask_PedirProcesso" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_Escola_di" bpmnElement="Participant_Escola" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1560" height="750" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_EE_di" bpmnElement="Lane_EE" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Secretaria_di" bpmnElement="Lane_Secretaria" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Direccao_di" bpmnElement="Lane_Direccao" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event — Lane EE -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="226" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End Event — Lane Secretaria -->
      <bpmndi:BPMNShape id="EndEvent_Final_di" bpmnElement="EndEvent_Final">
        <dc:Bounds x="1632" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1610" y="460" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Secretaria -->
      <bpmndi:BPMNShape id="Task_VerificarDoc_di" bpmnElement="Task_VerificarDoc">
        <dc:Bounds x="330" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ContactarEE_di" bpmnElement="Task_ContactarEE">
        <dc:Bounds x="480" y="325" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_RegistarSIGE_di" bpmnElement="Task_RegistarSIGE">
        <dc:Bounds x="620" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SendTask_PedirProcesso_di" bpmnElement="SendTask_PedirProcesso">
        <dc:Bounds x="850" y="325" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_NotificarEE_di" bpmnElement="Task_NotificarEE">
        <dc:Bounds x="1260" y="370" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ActualizarHorario_di" bpmnElement="Task_ActualizarHorario">
        <dc:Bounds x="1260" y="460" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Direcção -->
      <bpmndi:BPMNShape id="Task_DistribuirTurmas_di" bpmnElement="Task_DistribuirTurmas">
        <dc:Bounds x="1020" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateways -->
      <bpmndi:BPMNShape id="Gateway_DocCompleta_di" bpmnElement="Gateway_DocCompleta" isMarkerVisible="true">
        <dc:Bounds x="465" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="520" y="425" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Transferencia_di" bpmnElement="Gateway_Transferencia" isMarkerVisible="true">
        <dc:Bounds x="765" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="425" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_ParOpen_di" bpmnElement="Gateway_ParOpen">
        <dc:Bounds x="1175" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_ParClose_di" bpmnElement="Gateway_ParClose">
        <dc:Bounds x="1425" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Anotações -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="220" y="100" width="200" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="570" y="500" width="220" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="810" y="250" width="240" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Fluxos de sequência -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="270" y="203" />
        <di:waypoint x="270" y="435" />
        <di:waypoint x="330" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="435" />
        <di:waypoint x="465" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="490" y="410" />
        <di:waypoint x="490" y="365" />
        <di:waypoint x="480" y="365" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="493" y="378" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_LoopBack_di" bpmnElement="Flow_LoopBack">
        <di:waypoint x="530" y="325" />
        <di:waypoint x="530" y="300" />
        <di:waypoint x="380" y="300" />
        <di:waypoint x="380" y="395" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="515" y="435" />
        <di:waypoint x="620" y="435" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="555" y="417" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="720" y="435" />
        <di:waypoint x="765" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="790" y="410" />
        <di:waypoint x="790" y="365" />
        <di:waypoint x="850" y="365" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="378" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="950" y="365" />
        <di:waypoint x="985" y="365" />
        <di:waypoint x="985" y="685" />
        <di:waypoint x="1020" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="790" y="460" />
        <di:waypoint x="790" y="685" />
        <di:waypoint x="1020" y="685" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="470" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1120" y="685" />
        <di:waypoint x="1200" y="685" />
        <di:waypoint x="1200" y="460" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1200" y="410" />
        <di:waypoint x="1200" y="410" />
        <di:waypoint x="1260" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11b_di" bpmnElement="Flow_11b">
        <di:waypoint x="1200" y="460" />
        <di:waypoint x="1200" y="500" />
        <di:waypoint x="1260" y="500" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1360" y="410" />
        <di:waypoint x="1450" y="410" />
        <di:waypoint x="1450" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1360" y="500" />
        <di:waypoint x="1450" y="500" />
        <di:waypoint x="1450" y="460" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1475" y="435" />
        <di:waypoint x="1632" y="435" />
      </bpmndi:BPMNEdge>

      <!-- Associações (anotações) -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="270" y="167" />
        <di:waypoint x="290" y="140" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="670" y="475" />
        <di:waypoint x="670" y="500" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="900" y="325" />
        <di:waypoint x="900" y="290" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
