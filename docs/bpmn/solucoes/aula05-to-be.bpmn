<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Aula05"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_CMP" name="Câmara Municipal de Pombal — Processo Redesenhado (TO-BE)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Cidadao" name="Cidadão">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sistema" name="Sistema / Plataforma">
        <bpmn:flowNodeRef>Service_ValidarDados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Service_ClassificarServico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Classificacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Service_EncaminharPedido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateThrow_Notificar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Service_ActualizarEstado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Service_EncerrarPedido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Encerrado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TecAtendimento" name="Técnico de Atendimento">
        <bpmn:flowNodeRef>Task_TriagemManual</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ChefeDivisao" name="Chefe de Divisão">
        <bpmn:flowNodeRef>Task_ValidarAtribuir</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprovarIntervencao</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TecCampo" name="Técnico de Campo">
        <bpmn:flowNodeRef>Task_RealizarVisita</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Submeter pedido no portal municipal">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Encerrado" name="Pedido encerrado formalmente">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Service Tasks — Lane Sistema -->
    <bpmn:serviceTask id="Service_ValidarDados" name="Validar dados e atribuir número de registo">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Service_ClassificarServico" name="Classificar serviço responsável">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Service_EncaminharPedido" name="Encaminhar pedido e notificar chefe de divisão">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:intermediateThrowEvent id="IntermediateThrow_Notificar" name="Notificar cidadão: pedido em análise">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_1" />
    </bpmn:intermediateThrowEvent>

    <bpmn:serviceTask id="Service_ActualizarEstado" name="Actualizar estado e notificar cidadão: visita concluída">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Service_EncerrarPedido" name="Encerrar pedido e notificar cidadão">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateways — Lane Sistema -->
    <bpmn:exclusiveGateway id="Gateway_Classificacao" name="Classificação automática com confiança?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Merge">
      <bpmn:incoming>Flow_4a</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task — Lane Técnico de Atendimento -->
    <bpmn:task id="Task_TriagemManual" name="Triagem manual">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_4a</bpmn:outgoing>
    </bpmn:task>

    <!-- Tasks — Lane Chefe de Divisão -->
    <bpmn:task id="Task_ValidarAtribuir" name="Validar pedido e atribuir técnico de campo">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AprovarIntervencao" name="Aprovar intervenção">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <!-- Task — Lane Técnico de Campo -->
    <bpmn:task id="Task_RealizarVisita" name="Realizar visita e registar relatório na plataforma">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Service_ValidarDados" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Service_ValidarDados" targetRef="Service_ClassificarServico" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Service_ClassificarServico" targetRef="Gateway_Classificacao" />
    <bpmn:sequenceFlow id="Flow_4" name="Não" sourceRef="Gateway_Classificacao" targetRef="Task_TriagemManual" />
    <bpmn:sequenceFlow id="Flow_4a" sourceRef="Task_TriagemManual" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_5" name="Sim" sourceRef="Gateway_Classificacao" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_Merge" targetRef="Service_EncaminharPedido" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Service_EncaminharPedido" targetRef="Task_ValidarAtribuir" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ValidarAtribuir" targetRef="IntermediateThrow_Notificar" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="IntermediateThrow_Notificar" targetRef="Task_RealizarVisita" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_RealizarVisita" targetRef="Service_ActualizarEstado" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Service_ActualizarEstado" targetRef="Task_AprovarIntervencao" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_AprovarIntervencao" targetRef="Service_EncerrarPedido" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Service_EncerrarPedido" targetRef="EndEvent_Encerrado" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_CMP_di" bpmnElement="Participant_CMP" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1700" height="1000" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes (5 × 200px each) -->
      <bpmndi:BPMNShape id="Lane_Cidadao_di" bpmnElement="Lane_Cidadao" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1670" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Sistema_di" bpmnElement="Lane_Sistema" isHorizontal="true">
        <dc:Bounds x="190" y="260" width="1670" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TecAtendimento_di" bpmnElement="Lane_TecAtendimento" isHorizontal="true">
        <dc:Bounds x="190" y="460" width="1670" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ChefeDivisao_di" bpmnElement="Lane_ChefeDivisao" isHorizontal="true">
        <dc:Bounds x="190" y="660" width="1670" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TecCampo_di" bpmnElement="Lane_TecCampo" isHorizontal="true">
        <dc:Bounds x="190" y="860" width="1670" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event — Lane Cidadão (y center ~160) -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="272" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="246" y="185" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Service Tasks — Lane Sistema (y center ~360) -->
      <bpmndi:BPMNShape id="Service_ValidarDados_di" bpmnElement="Service_ValidarDados">
        <dc:Bounds x="310" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Service_ClassificarServico_di" bpmnElement="Service_ClassificarServico">
        <dc:Bounds x="460" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Classificacao_di" bpmnElement="Gateway_Classificacao" isMarkerVisible="true">
        <dc:Bounds x="615" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="670" y="340" width="90" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Lane Técnico de Atendimento (y center ~560) -->
      <bpmndi:BPMNShape id="Task_TriagemManual_di" bpmnElement="Task_TriagemManual">
        <dc:Bounds x="700" y="520" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Merge Gateway — Lane Sistema -->
      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="835" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Service_EncaminharPedido_di" bpmnElement="Service_EncaminharPedido">
        <dc:Bounds x="930" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tasks — Lane Chefe de Divisão (y center ~760) -->
      <bpmndi:BPMNShape id="Task_ValidarAtribuir_di" bpmnElement="Task_ValidarAtribuir">
        <dc:Bounds x="930" y="720" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Intermediate Throw Event — Lane Sistema -->
      <bpmndi:BPMNShape id="IntermediateThrow_Notificar_di" bpmnElement="IntermediateThrow_Notificar">
        <dc:Bounds x="1082" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1056" y="385" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Lane Técnico de Campo (y center ~960) -->
      <bpmndi:BPMNShape id="Task_RealizarVisita_di" bpmnElement="Task_RealizarVisita">
        <dc:Bounds x="1150" y="920" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Service Task — Lane Sistema -->
      <bpmndi:BPMNShape id="Service_ActualizarEstado_di" bpmnElement="Service_ActualizarEstado">
        <dc:Bounds x="1300" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Lane Chefe de Divisão -->
      <bpmndi:BPMNShape id="Task_AprovarIntervencao_di" bpmnElement="Task_AprovarIntervencao">
        <dc:Bounds x="1300" y="720" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Service Task — Lane Sistema -->
      <bpmndi:BPMNShape id="Service_EncerrarPedido_di" bpmnElement="Service_EncerrarPedido">
        <dc:Bounds x="1480" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event — Lane Sistema -->
      <bpmndi:BPMNShape id="EndEvent_Encerrado_di" bpmnElement="EndEvent_Encerrado">
        <dc:Bounds x="1642" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1616" y="385" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Fluxos de sequência -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="290" y="178" />
        <di:waypoint x="290" y="360" />
        <di:waypoint x="310" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="410" y="360" />
        <di:waypoint x="460" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="360" />
        <di:waypoint x="615" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="640" y="385" />
        <di:waypoint x="640" y="560" />
        <di:waypoint x="700" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="648" y="470" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4a_di" bpmnElement="Flow_4a">
        <di:waypoint x="800" y="560" />
        <di:waypoint x="860" y="560" />
        <di:waypoint x="860" y="385" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="665" y="360" />
        <di:waypoint x="835" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="740" y="342" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="885" y="360" />
        <di:waypoint x="930" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="980" y="400" />
        <di:waypoint x="980" y="720" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1030" y="760" />
        <di:waypoint x="1100" y="760" />
        <di:waypoint x="1100" y="378" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1118" y="360" />
        <di:waypoint x="1134" y="360" />
        <di:waypoint x="1134" y="960" />
        <di:waypoint x="1150" y="960" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1250" y="960" />
        <di:waypoint x="1275" y="960" />
        <di:waypoint x="1275" y="360" />
        <di:waypoint x="1300" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1350" y="400" />
        <di:waypoint x="1350" y="720" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1400" y="760" />
        <di:waypoint x="1440" y="760" />
        <di:waypoint x="1440" y="360" />
        <di:waypoint x="1480" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1580" y="360" />
        <di:waypoint x="1642" y="360" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
