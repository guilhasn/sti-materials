<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Caso3"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Camara" name="Câmara Municipal de Marinha Grande — Licença de Ruído para Evento (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Requerente" name="Requerente">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PagarTaxa</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gabinete" name="Gabinete de Apoio">
        <bpmn:flowNodeRef>Task_VerificarForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ZonaPermitida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IndeferirPedido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Indeferido1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepararInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarIndeferimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Indeferido2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComunicarDecisao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_EnviarPSP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirAlvara</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Vereador" name="Vereador">
        <bpmn:flowNodeRef>Task_AnalisarDespachar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decisao</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Requerente entrega formulário">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Indeferido1" name="Pedido indeferido (zona)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Indeferido2" name="Pedido indeferido (despacho)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Final" name="Processo concluído">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Tarefas — Lane Gabinete -->
    <bpmn:task id="Task_VerificarForm" name="Verificar formulário e zona">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_IndeferirPedido" name="Indeferir pedido">
      <bpmn:incoming>Flow_2b</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepararInfo" name="Preparar informação técnica">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ComunicarIndeferimento" name="Comunicar indeferimento ao requerente">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ComunicarDecisao" name="Comunicar decisão ao requerente">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_EnviarPSP" name="Enviar ofício à PSP para fiscalização">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_EmitirAlvara" name="Emitir alvará de licença">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Requerente -->
    <bpmn:task id="Task_PagarTaxa" name="Pagar taxa no balcão">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Vereador -->
    <bpmn:task id="Task_AnalisarDespachar" name="Analisar e despachar">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateways -->
    <bpmn:exclusiveGateway id="Gateway_ZonaPermitida" name="Zona e horário permitidos?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_2b</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Decisao" name="Decisão?">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarForm" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarForm" targetRef="Gateway_ZonaPermitida" />
    <bpmn:sequenceFlow id="Flow_2b" name="Não" sourceRef="Gateway_ZonaPermitida" targetRef="Task_IndeferirPedido" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_IndeferirPedido" targetRef="EndEvent_Indeferido1" />
    <bpmn:sequenceFlow id="Flow_4" name="Sim" sourceRef="Gateway_ZonaPermitida" targetRef="Task_PrepararInfo" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_PrepararInfo" targetRef="Task_AnalisarDespachar" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_AnalisarDespachar" targetRef="Gateway_Decisao" />
    <bpmn:sequenceFlow id="Flow_7" name="Indeferido" sourceRef="Gateway_Decisao" targetRef="Task_ComunicarIndeferimento" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ComunicarIndeferimento" targetRef="EndEvent_Indeferido2" />
    <bpmn:sequenceFlow id="Flow_9" name="Deferido" sourceRef="Gateway_Decisao" targetRef="Task_ComunicarDecisao" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_ComunicarDecisao" targetRef="SendTask_EnviarPSP" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="SendTask_EnviarPSP" targetRef="Task_PagarTaxa" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_PagarTaxa" targetRef="Task_EmitirAlvara" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_EmitirAlvara" targetRef="EndEvent_Final" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Formulário em papel — requerente pode ter de voltar por dados em falta</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Task_VerificarForm" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Comunicação à PSP por ofício — pode não chegar a tempo do evento</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="SendTask_EnviarPSP" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Nenhuma verificação no dia do evento — condições podem ser violadas</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="EndEvent_Final" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_Camara_di" bpmnElement="Participant_Camara" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1560" height="750" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Requerente_di" bpmnElement="Lane_Requerente" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gabinete_di" bpmnElement="Lane_Gabinete" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Vereador_di" bpmnElement="Lane_Vereador" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event — Lane Requerente -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="226" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End Events -->
      <bpmndi:BPMNShape id="EndEvent_Indeferido1_di" bpmnElement="EndEvent_Indeferido1">
        <dc:Bounds x="662" y="347" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="636" y="390" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Indeferido2_di" bpmnElement="EndEvent_Indeferido2">
        <dc:Bounds x="842" y="327" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="816" y="310" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Final_di" bpmnElement="EndEvent_Final">
        <dc:Bounds x="1632" y="417" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1610" y="460" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Gabinete -->
      <bpmndi:BPMNShape id="Task_VerificarForm_di" bpmnElement="Task_VerificarForm">
        <dc:Bounds x="310" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_IndeferirPedido_di" bpmnElement="Task_IndeferirPedido">
        <dc:Bounds x="530" y="325" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_PrepararInfo_di" bpmnElement="Task_PrepararInfo">
        <dc:Bounds x="530" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ComunicarIndeferimento_di" bpmnElement="Task_ComunicarIndeferimento">
        <dc:Bounds x="810" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ComunicarDecisao_di" bpmnElement="Task_ComunicarDecisao">
        <dc:Bounds x="960" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SendTask_EnviarPSP_di" bpmnElement="SendTask_EnviarPSP">
        <dc:Bounds x="1110" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EmitirAlvara_di" bpmnElement="Task_EmitirAlvara">
        <dc:Bounds x="1420" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Requerente -->
      <bpmndi:BPMNShape id="Task_PagarTaxa_di" bpmnElement="Task_PagarTaxa">
        <dc:Bounds x="1260" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Vereador -->
      <bpmndi:BPMNShape id="Task_AnalisarDespachar_di" bpmnElement="Task_AnalisarDespachar">
        <dc:Bounds x="660" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateways -->
      <bpmndi:BPMNShape id="Gateway_ZonaPermitida_di" bpmnElement="Gateway_ZonaPermitida" isMarkerVisible="true">
        <dc:Bounds x="445" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="500" y="425" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Decisao_di" bpmnElement="Gateway_Decisao" isMarkerVisible="true">
        <dc:Bounds x="785" y="660" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="840" y="675" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Anotações -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="260" y="500" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="1070" y="500" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="1560" y="340" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Fluxos de sequência -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="270" y="203" />
        <di:waypoint x="270" y="435" />
        <di:waypoint x="310" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="410" y="435" />
        <di:waypoint x="445" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2b_di" bpmnElement="Flow_2b">
        <di:waypoint x="470" y="410" />
        <di:waypoint x="470" y="365" />
        <di:waypoint x="530" y="365" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="475" y="378" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="630" y="365" />
        <di:waypoint x="662" y="365" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="470" y="460" />
        <di:waypoint x="470" y="495" />
        <di:waypoint x="530" y="495" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="478" y="473" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="630" y="495" />
        <di:waypoint x="645" y="495" />
        <di:waypoint x="645" y="685" />
        <di:waypoint x="660" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="760" y="685" />
        <di:waypoint x="785" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="810" y="660" />
        <di:waypoint x="810" y="560" />
        <di:waypoint x="860" y="560" />
        <di:waypoint x="860" y="475" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="815" y="600" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="860" y="395" />
        <di:waypoint x="860" y="363" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="835" y="685" />
        <di:waypoint x="1010" y="685" />
        <di:waypoint x="1010" y="475" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="900" y="667" width="42" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1060" y="435" />
        <di:waypoint x="1110" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1210" y="435" />
        <di:waypoint x="1235" y="435" />
        <di:waypoint x="1235" y="185" />
        <di:waypoint x="1260" y="185" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1360" y="185" />
        <di:waypoint x="1390" y="185" />
        <di:waypoint x="1390" y="435" />
        <di:waypoint x="1420" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1520" y="435" />
        <di:waypoint x="1632" y="435" />
      </bpmndi:BPMNEdge>

      <!-- Associações (anotações) -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="360" y="475" />
        <di:waypoint x="370" y="500" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="1160" y="475" />
        <di:waypoint x="1170" y="500" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="1650" y="417" />
        <di:waypoint x="1660" y="380" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
