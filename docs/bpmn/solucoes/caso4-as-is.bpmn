<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Caso4"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_CentroSaude" name="Centro de Saúde de Pombal — Marcação e Realização de Consulta (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Utente" name="Utente">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_AguardarConsulta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApresentarRecepcao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MarcarExames</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Recepcao" name="Recepção">
        <bpmn:flowNodeRef>Task_VerificarDisponibilidade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HaVaga</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistarListaEspera</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ListaEspera</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MarcarConsulta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmarPresenca</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Enfermeiro" name="Enfermeiro">
        <bpmn:flowNodeRef>Task_PreTriagem</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistarValores</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Medico" name="Médico">
        <bpmn:flowNodeRef>Task_RealizarConsulta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NecessitaExames</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirRequisicao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MergeExames</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NecessitaReceita</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirReceita</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MergeReceita</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Utente contacta recepção">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_ListaEspera" name="Processo interrompido (lista de espera)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Final" name="Processo concluído">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Intermediate Timer Catch Event — Lane Utente -->
    <bpmn:intermediateCatchEvent id="Timer_AguardarConsulta" name="Aguardar dia da consulta">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_1" />
    </bpmn:intermediateCatchEvent>

    <!-- Tarefas — Lane Utente -->
    <bpmn:task id="Task_ApresentarRecepcao" name="Apresentar-se na recepção">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MarcarExames" name="Marcar exames ou próxima consulta na recepção">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Recepção -->
    <bpmn:task id="Task_VerificarDisponibilidade" name="Verificar disponibilidade na agenda">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegistarListaEspera" name="Registar em lista de espera">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MarcarConsulta" name="Marcar consulta e informar utente">
      <bpmn:incoming>Flow_5a</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ConfirmarPresenca" name="Confirmar presença e preparar ficha">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Enfermeiro -->
    <bpmn:task id="Task_PreTriagem" name="Realizar pré-triagem (tensão, peso, temperatura)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegistarValores" name="Registar valores na ficha">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Médico -->
    <bpmn:task id="Task_RealizarConsulta" name="Realizar consulta">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EmitirRequisicao" name="Emitir requisição de exames (papel)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EmitirReceita" name="Emitir receita electrónica">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateways -->
    <bpmn:exclusiveGateway id="Gateway_HaVaga" name="Há vaga?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_5a</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_NecessitaExames" name="Necessita exames?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_12a</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_MergeExames">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_12a</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_NecessitaReceita" name="Necessita receita?">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_15a</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_MergeReceita">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:incoming>Flow_15a</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarDisponibilidade" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarDisponibilidade" targetRef="Gateway_HaVaga" />
    <bpmn:sequenceFlow id="Flow_3" name="Não" sourceRef="Gateway_HaVaga" targetRef="Task_RegistarListaEspera" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_RegistarListaEspera" targetRef="EndEvent_ListaEspera" />
    <bpmn:sequenceFlow id="Flow_5a" name="Sim" sourceRef="Gateway_HaVaga" targetRef="Task_MarcarConsulta" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_MarcarConsulta" targetRef="Timer_AguardarConsulta" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Timer_AguardarConsulta" targetRef="Task_ApresentarRecepcao" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ApresentarRecepcao" targetRef="Task_ConfirmarPresenca" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ConfirmarPresenca" targetRef="Task_PreTriagem" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_PreTriagem" targetRef="Task_RegistarValores" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_RegistarValores" targetRef="Task_RealizarConsulta" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_RealizarConsulta" targetRef="Gateway_NecessitaExames" />
    <bpmn:sequenceFlow id="Flow_12" name="Sim" sourceRef="Gateway_NecessitaExames" targetRef="Task_EmitirRequisicao" />
    <bpmn:sequenceFlow id="Flow_12a" name="Não" sourceRef="Gateway_NecessitaExames" targetRef="Gateway_MergeExames" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_EmitirRequisicao" targetRef="Gateway_MergeExames" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Gateway_MergeExames" targetRef="Gateway_NecessitaReceita" />
    <bpmn:sequenceFlow id="Flow_15" name="Sim" sourceRef="Gateway_NecessitaReceita" targetRef="Task_EmitirReceita" />
    <bpmn:sequenceFlow id="Flow_15a" name="Não" sourceRef="Gateway_NecessitaReceita" targetRef="Gateway_MergeReceita" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_EmitirReceita" targetRef="Gateway_MergeReceita" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Gateway_MergeReceita" targetRef="Task_MarcarExames" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_MarcarExames" targetRef="EndEvent_Final" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Lista de espera em caderno de papel — utentes esquecidos</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Task_RegistarListaEspera" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Utente sem previsão de tempo de espera — insatisfação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="Timer_AguardarConsulta" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Ficha de papel — valores de pré-triagem podem perder-se</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="Task_RegistarValores" targetRef="TextAnnotation_3" />

    <bpmn:textAnnotation id="TextAnnotation_4">
      <bpmn:text>⚠ Chamada em voz alta — utentes não ouvem, perdem a vez</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_4" sourceRef="Task_RealizarConsulta" targetRef="TextAnnotation_4" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_CentroSaude_di" bpmnElement="Participant_CentroSaude" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1700" height="1000" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Utente_di" bpmnElement="Lane_Utente" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Recepcao_di" bpmnElement="Lane_Recepcao" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Enfermeiro_di" bpmnElement="Lane_Enfermeiro" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Medico_di" bpmnElement="Lane_Medico" isHorizontal="true">
        <dc:Bounds x="190" y="810" width="1670" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event — Lane Utente -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="228" y="210" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Lane Recepção: Verificar disponibilidade -->
      <bpmndi:BPMNShape id="Task_VerificarDisponibilidade_di" bpmnElement="Task_VerificarDisponibilidade">
        <dc:Bounds x="310" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Há vaga? -->
      <bpmndi:BPMNShape id="Gateway_HaVaga_di" bpmnElement="Gateway_HaVaga" isMarkerVisible="true">
        <dc:Bounds x="455" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="510" y="425" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Registar lista de espera (Não path) -->
      <bpmndi:BPMNShape id="Task_RegistarListaEspera_di" bpmnElement="Task_RegistarListaEspera">
        <dc:Bounds x="560" y="335" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event — Lista de espera -->
      <bpmndi:BPMNShape id="EndEvent_ListaEspera_di" bpmnElement="EndEvent_ListaEspera">
        <dc:Bounds x="712" y="357" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="686" y="400" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Marcar consulta (Sim path) -->
      <bpmndi:BPMNShape id="Task_MarcarConsulta_di" bpmnElement="Task_MarcarConsulta">
        <dc:Bounds x="560" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Timer Intermediate Catch Event — Lane Utente -->
      <bpmndi:BPMNShape id="Timer_AguardarConsulta_di" bpmnElement="Timer_AguardarConsulta">
        <dc:Bounds x="712" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="690" y="210" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Apresentar-se na recepção — Lane Utente -->
      <bpmndi:BPMNShape id="Task_ApresentarRecepcao_di" bpmnElement="Task_ApresentarRecepcao">
        <dc:Bounds x="800" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Confirmar presença — Lane Recepção -->
      <bpmndi:BPMNShape id="Task_ConfirmarPresenca_di" bpmnElement="Task_ConfirmarPresenca">
        <dc:Bounds x="800" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Pré-triagem — Lane Enfermeiro -->
      <bpmndi:BPMNShape id="Task_PreTriagem_di" bpmnElement="Task_PreTriagem">
        <dc:Bounds x="800" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Registar valores — Lane Enfermeiro -->
      <bpmndi:BPMNShape id="Task_RegistarValores_di" bpmnElement="Task_RegistarValores">
        <dc:Bounds x="950" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Realizar consulta — Lane Médico -->
      <bpmndi:BPMNShape id="Task_RealizarConsulta_di" bpmnElement="Task_RealizarConsulta">
        <dc:Bounds x="950" y="895" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Necessita exames? -->
      <bpmndi:BPMNShape id="Gateway_NecessitaExames_di" bpmnElement="Gateway_NecessitaExames" isMarkerVisible="true">
        <dc:Bounds x="1095" y="910" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1080" y="963" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Emitir requisição exames — Lane Médico -->
      <bpmndi:BPMNShape id="Task_EmitirRequisicao_di" bpmnElement="Task_EmitirRequisicao">
        <dc:Bounds x="1170" y="840" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Merge Exames -->
      <bpmndi:BPMNShape id="Gateway_MergeExames_di" bpmnElement="Gateway_MergeExames" isMarkerVisible="true">
        <dc:Bounds x="1305" y="910" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Necessita receita? -->
      <bpmndi:BPMNShape id="Gateway_NecessitaReceita_di" bpmnElement="Gateway_NecessitaReceita" isMarkerVisible="true">
        <dc:Bounds x="1395" y="910" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1380" y="963" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task — Emitir receita — Lane Médico -->
      <bpmndi:BPMNShape id="Task_EmitirReceita_di" bpmnElement="Task_EmitirReceita">
        <dc:Bounds x="1470" y="840" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Merge Receita -->
      <bpmndi:BPMNShape id="Gateway_MergeReceita_di" bpmnElement="Gateway_MergeReceita" isMarkerVisible="true">
        <dc:Bounds x="1605" y="910" width="50" height="50" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task — Marcar exames — Lane Utente -->
      <bpmndi:BPMNShape id="Task_MarcarExames_di" bpmnElement="Task_MarcarExames">
        <dc:Bounds x="1605" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event Final — Lane Utente -->
      <bpmndi:BPMNShape id="EndEvent_Final_di" bpmnElement="EndEvent_Final">
        <dc:Bounds x="1752" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1730" y="210" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Anotações -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="540" y="260" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="660" y="80" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="920" y="760" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_4_di" bpmnElement="TextAnnotation_4">
        <dc:Bounds x="1070" y="820" width="250" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Fluxos de sequência -->
      <!-- Flow_1: Start → Verificar disponibilidade -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="270" y="203" />
        <di:waypoint x="270" y="435" />
        <di:waypoint x="310" y="435" />
      </bpmndi:BPMNEdge>

      <!-- Flow_2: Verificar disponibilidade → Gateway Há vaga? -->
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="410" y="435" />
        <di:waypoint x="455" y="435" />
      </bpmndi:BPMNEdge>

      <!-- Flow_3: Gateway → Registar lista espera (Não) -->
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="480" y="410" />
        <di:waypoint x="480" y="375" />
        <di:waypoint x="560" y="375" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="488" y="383" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_4: Registar lista espera → End -->
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="660" y="375" />
        <di:waypoint x="712" y="375" />
      </bpmndi:BPMNEdge>

      <!-- Flow_5a: Gateway → Marcar consulta (Sim) -->
      <bpmndi:BPMNEdge id="Flow_5a_di" bpmnElement="Flow_5a">
        <di:waypoint x="480" y="460" />
        <di:waypoint x="480" y="495" />
        <di:waypoint x="560" y="495" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="488" y="473" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_5: Marcar consulta → Timer -->
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="660" y="495" />
        <di:waypoint x="730" y="495" />
        <di:waypoint x="730" y="203" />
      </bpmndi:BPMNEdge>

      <!-- Flow_6: Timer → Apresentar-se -->
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="748" y="185" />
        <di:waypoint x="800" y="185" />
      </bpmndi:BPMNEdge>

      <!-- Flow_7: Apresentar-se → Confirmar presença -->
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="850" y="225" />
        <di:waypoint x="850" y="395" />
      </bpmndi:BPMNEdge>

      <!-- Flow_8: Confirmar presença → Pré-triagem -->
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="850" y="475" />
        <di:waypoint x="850" y="645" />
      </bpmndi:BPMNEdge>

      <!-- Flow_9: Pré-triagem → Registar valores -->
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="900" y="685" />
        <di:waypoint x="950" y="685" />
      </bpmndi:BPMNEdge>

      <!-- Flow_10: Registar valores → Realizar consulta -->
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1000" y="725" />
        <di:waypoint x="1000" y="895" />
      </bpmndi:BPMNEdge>

      <!-- Flow_11: Realizar consulta → Gateway Necessita exames? -->
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1050" y="935" />
        <di:waypoint x="1095" y="935" />
      </bpmndi:BPMNEdge>

      <!-- Flow_12: Gateway → Emitir requisição (Sim) -->
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1120" y="910" />
        <di:waypoint x="1120" y="880" />
        <di:waypoint x="1170" y="880" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1128" y="888" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_12a: Gateway → Merge Exames (Não) -->
      <bpmndi:BPMNEdge id="Flow_12a_di" bpmnElement="Flow_12a">
        <di:waypoint x="1145" y="935" />
        <di:waypoint x="1305" y="935" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1210" y="917" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_13: Emitir requisição → Merge Exames -->
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1270" y="880" />
        <di:waypoint x="1330" y="880" />
        <di:waypoint x="1330" y="910" />
      </bpmndi:BPMNEdge>

      <!-- Flow_14: Merge Exames → Gateway Necessita receita? -->
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1355" y="935" />
        <di:waypoint x="1395" y="935" />
      </bpmndi:BPMNEdge>

      <!-- Flow_15: Gateway → Emitir receita (Sim) -->
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1420" y="910" />
        <di:waypoint x="1420" y="880" />
        <di:waypoint x="1470" y="880" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1428" y="888" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_15a: Gateway → Merge Receita (Não) -->
      <bpmndi:BPMNEdge id="Flow_15a_di" bpmnElement="Flow_15a">
        <di:waypoint x="1445" y="935" />
        <di:waypoint x="1605" y="935" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1510" y="917" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Flow_16: Emitir receita → Merge Receita -->
      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1570" y="880" />
        <di:waypoint x="1630" y="880" />
        <di:waypoint x="1630" y="910" />
      </bpmndi:BPMNEdge>

      <!-- Flow_17: Merge Receita → Marcar exames (Utente lane) -->
      <bpmndi:BPMNEdge id="Flow_17_di" bpmnElement="Flow_17">
        <di:waypoint x="1655" y="935" />
        <di:waypoint x="1680" y="935" />
        <di:waypoint x="1680" y="225" />
        <di:waypoint x="1655" y="225" />
      </bpmndi:BPMNEdge>

      <!-- Flow_18: Marcar exames → End -->
      <bpmndi:BPMNEdge id="Flow_18_di" bpmnElement="Flow_18">
        <di:waypoint x="1705" y="185" />
        <di:waypoint x="1752" y="185" />
      </bpmndi:BPMNEdge>

      <!-- Associações (anotações) -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="610" y="335" />
        <di:waypoint x="620" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="730" y="167" />
        <di:waypoint x="730" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="1000" y="725" />
        <di:waypoint x="1010" y="760" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_4_di" bpmnElement="Association_4">
        <di:waypoint x="1050" y="895" />
        <di:waypoint x="1100" y="860" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
