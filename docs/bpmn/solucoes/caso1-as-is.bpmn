<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Caso1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="bpmn-js"
                  exporterVersion="12.0.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_LojaCidadao" name="Loja do Cidadão — Pedido de Subsídio de Desemprego (AS-IS)" processRef="Process_1" />
  </bpmn:collaboration>

  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Cidadao" name="Cidadão">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceberCarta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Final</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Tecnico" name="Técnico de Atendimento">
        <bpmn:flowNodeRef>Task_VerificarDoc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DocCompleta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformarFalta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DocIncompleta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PreencherForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ImprimirComprov</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Backoffice" name="Back-office Segurança Social">
        <bpmn:flowNodeRef>Task_VerificarHistorico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DadosConsistentes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SolicitarEsclarec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirDecisao</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Eventos -->
    <bpmn:startEvent id="StartEvent_1" name="Cidadão apresenta-se com documentação">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_DocIncompleta" name="Pedido não prossegue (documentação incompleta)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Final" name="Processo concluído">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Tarefas — Lane Técnico -->
    <bpmn:task id="Task_VerificarDoc" name="Verificar identidade e documentação">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_InformarFalta" name="Informar cidadão do que falta">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PreencherForm" name="Preencher formulário de pedido no sistema">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ImprimirComprov" name="Imprimir e entregar comprovativo ao cidadão">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Back-office -->
    <bpmn:task id="Task_VerificarHistorico" name="Verificar histórico contributivo (consulta manual)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SolicitarEsclarec" name="Solicitar esclarecimento ao atendimento (email)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EmitirDecisao" name="Emitir decisão (deferido / indeferido)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <!-- Tarefas — Lane Cidadão -->
    <bpmn:task id="Task_ReceberCarta" name="Receber carta com decisão (7–15 dias depois)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <!-- Gateways -->
    <bpmn:exclusiveGateway id="Gateway_DocCompleta" name="Documentação completa?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_DadosConsistentes" name="Dados consistentes?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fluxos de sequência -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_VerificarDoc" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_VerificarDoc" targetRef="Gateway_DocCompleta" />
    <bpmn:sequenceFlow id="Flow_3" name="Não" sourceRef="Gateway_DocCompleta" targetRef="Task_InformarFalta" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_InformarFalta" targetRef="EndEvent_DocIncompleta" />
    <bpmn:sequenceFlow id="Flow_5" name="Sim" sourceRef="Gateway_DocCompleta" targetRef="Task_PreencherForm" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_PreencherForm" targetRef="Task_ImprimirComprov" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ImprimirComprov" targetRef="Task_VerificarHistorico" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_VerificarHistorico" targetRef="Gateway_DadosConsistentes" />
    <bpmn:sequenceFlow id="Flow_9" name="Não" sourceRef="Gateway_DadosConsistentes" targetRef="Task_SolicitarEsclarec" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_SolicitarEsclarec" targetRef="Task_VerificarHistorico" />
    <bpmn:sequenceFlow id="Flow_11" name="Sim" sourceRef="Gateway_DadosConsistentes" targetRef="Task_EmitirDecisao" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_EmitirDecisao" targetRef="Task_ReceberCarta" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_ReceberCarta" targetRef="EndEvent_Final" />

    <!-- Anotações de texto -->
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>⚠ Formulário sem validação — dados podem estar incompletos</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="Task_PreencherForm" targetRef="TextAnnotation_1" />

    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>⚠ Consulta manual a outro sistema — lento e propenso a erro</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" sourceRef="Task_VerificarHistorico" targetRef="TextAnnotation_2" />

    <bpmn:textAnnotation id="TextAnnotation_3">
      <bpmn:text>⚠ Cidadão espera 7–15 dias sem qualquer actualização</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_3" sourceRef="Task_ReceberCarta" targetRef="TextAnnotation_3" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

      <!-- Pool -->
      <bpmndi:BPMNShape id="Participant_LojaCidadao_di" bpmnElement="Participant_LojaCidadao" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1560" height="750" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Cidadao_di" bpmnElement="Lane_Cidadao" isHorizontal="true">
        <dc:Bounds x="190" y="60" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Tecnico_di" bpmnElement="Lane_Tecnico" isHorizontal="true">
        <dc:Bounds x="190" y="310" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Backoffice_di" bpmnElement="Lane_Backoffice" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1530" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Eventos -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="252" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="226" y="210" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_DocIncompleta_di" bpmnElement="EndEvent_DocIncompleta">
        <dc:Bounds x="752" y="347" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="726" y="390" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Final_di" bpmnElement="EndEvent_Final">
        <dc:Bounds x="1592" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1570" y="210" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Técnico -->
      <bpmndi:BPMNShape id="Task_VerificarDoc_di" bpmnElement="Task_VerificarDoc">
        <dc:Bounds x="330" y="395" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_InformarFalta_di" bpmnElement="Task_InformarFalta">
        <dc:Bounds x="580" y="325" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_PreencherForm_di" bpmnElement="Task_PreencherForm">
        <dc:Bounds x="580" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ImprimirComprov_di" bpmnElement="Task_ImprimirComprov">
        <dc:Bounds x="740" y="455" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Back-office -->
      <bpmndi:BPMNShape id="Task_VerificarHistorico_di" bpmnElement="Task_VerificarHistorico">
        <dc:Bounds x="900" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_SolicitarEsclarec_di" bpmnElement="Task_SolicitarEsclarec">
        <dc:Bounds x="1070" y="575" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_EmitirDecisao_di" bpmnElement="Task_EmitirDecisao">
        <dc:Bounds x="1240" y="645" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Tarefas — Lane Cidadão -->
      <bpmndi:BPMNShape id="Task_ReceberCarta_di" bpmnElement="Task_ReceberCarta">
        <dc:Bounds x="1400" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateways -->
      <bpmndi:BPMNShape id="Gateway_DocCompleta_di" bpmnElement="Gateway_DocCompleta" isMarkerVisible="true">
        <dc:Bounds x="495" y="410" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="550" y="425" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_DadosConsistentes_di" bpmnElement="Gateway_DadosConsistentes" isMarkerVisible="true">
        <dc:Bounds x="1095" y="660" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1150" y="675" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Anotações -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="530" y="560" width="200" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_2_di" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="830" y="770" width="240" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_3_di" bpmnElement="TextAnnotation_3">
        <dc:Bounds x="1360" y="70" width="220" height="40" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Fluxos de sequência -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="270" y="203" />
        <di:waypoint x="270" y="435" />
        <di:waypoint x="330" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="430" y="435" />
        <di:waypoint x="495" y="435" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="520" y="410" />
        <di:waypoint x="520" y="365" />
        <di:waypoint x="580" y="365" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="525" y="378" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="680" y="365" />
        <di:waypoint x="752" y="365" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="520" y="460" />
        <di:waypoint x="520" y="495" />
        <di:waypoint x="580" y="495" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="528" y="473" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="680" y="495" />
        <di:waypoint x="740" y="495" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="840" y="495" />
        <di:waypoint x="870" y="495" />
        <di:waypoint x="870" y="685" />
        <di:waypoint x="900" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1000" y="685" />
        <di:waypoint x="1095" y="685" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1120" y="660" />
        <di:waypoint x="1120" y="655" />
        <di:waypoint x="1070" y="615" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1075" y="640" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1070" y="615" />
        <di:waypoint x="960" y="615" />
        <di:waypoint x="960" y="645" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1145" y="685" />
        <di:waypoint x="1240" y="685" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1170" y="667" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1340" y="685" />
        <di:waypoint x="1450" y="685" />
        <di:waypoint x="1450" y="225" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1500" y="185" />
        <di:waypoint x="1592" y="185" />
      </bpmndi:BPMNEdge>

      <!-- Associações (anotações) -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="630" y="535" />
        <di:waypoint x="630" y="560" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="950" y="725" />
        <di:waypoint x="950" y="770" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_3_di" bpmnElement="Association_3">
        <di:waypoint x="1450" y="145" />
        <di:waypoint x="1460" y="110" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
